# ===================== SERVIDOR =====================
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
# Poner true en Railway/Render/Fly para confiar en X-Forwarded-For
TRUST_PROXY=false

# CORS: orígenes del frontend permitidos (separados por coma)
# Vite + Vue = 5173 | Vue CLI = 8080 | Angular = 4200 | Next.js/CRA = 3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000,http://localhost:4200

# ===================== BASE DE DATOS (PostgreSQL) =====================
DB_HOST=localhost
DB_PORT=5433
DB_NAME=ecommerce_db
DB_USER=ecommerce_user
DB_PASSWORD=tu_password_aqui# Poner true si usas Neon, Supabase u otro servicio en la nube
DB_SSL=false
# ===================== JWT =====================
# Generar secreto seguro: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro
JWT_EXPIRES_IN=24h

# ===================== EMAIL (Sendgrid) =====================
SENDGRID_API_KEY=tu_api_key_de_sendgrid_aqui
EMAIL_FROM=tu_email_verificado_en_sendgrid@example.com

# ===================== CLOUDINARY (imágenes de productos) =====================
# Crear cuenta en: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ===================== PAGOS (Simulación) =====================
# Porcentaje de pagos aprobados automáticamente (0-100)
PAYMENT_APPROVAL_RATE=80
GEMINI_API_KEY=CABEZON PUSO EL APIKEY ENEL ENV DE EJEMPLO XDDDDD
